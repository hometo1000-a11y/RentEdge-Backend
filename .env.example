# ─── SERVER CONFIG ──────────────────────────────────────────────────
PORT=5000
FRONTEND_URL=http://localhost:3000
JWT_SECRET=your_jwt_secret_here

# ─── SUPABASE DATABASE CONFIG ───────────────────────────────────────
DATABASE_URL=postgresql://postgres.your_project:your_password@aws-1-ap-south-1.pooler.supabase.com:5432/postgres

# ─── SUPABASE AUTH & API CONFIG ─────────────────────────────────────
SUPABASE_URL=https://your_project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_REST_URL=https://your_project.supabase.co/rest/v1/

# ─── FIREBASE CONFIG ────────────────────────────────────────────────
# Firebase Admin SDK & Web Auth Keys
FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_AUTH_DOMAIN=your_firebase_auth_domain
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_STORAGE_BUCKET=your_firebase_storage_bucket
FIREBASE_MESSAGING_SENDER_ID=your_firebase_messaging_sender_id
FIREBASE_APP_ID=your_firebase_app_id
FIREBASE_MEASUREMENT_ID=your_firebase_measurement_id
FIREBASE_PHONE_AUTH_TESTING_API=your_firebase_testing_api_key

# Relative or absolute path to your downloaded Firebase Service Account JSON
FIREBASE_SERVICE_ACCOUNT_PATH=../your-firebase-service-account.json

# ─── IMAGEKIT CONFIG ────────────────────────────────────────────────
IMAGEKIT_PUBLIC_KEY=your_imagekit_public_key
IMAGEKIT_PRIVATE_KEY=your_imagekit_private_key
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_endpoint
